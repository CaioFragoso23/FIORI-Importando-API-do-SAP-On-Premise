                <Collection>
                    <PropertyPath>Customer</PropertyPath>
                    <PropertyPath>CustomerName</PropertyPath>
                </Collection>
            </Annotation>

            <Annotation Term="UI.LineItem">
                <Collection>
                    <Record Type="UI.DataField">
                        <PropertyValue Property="Label" String="Account group" />
