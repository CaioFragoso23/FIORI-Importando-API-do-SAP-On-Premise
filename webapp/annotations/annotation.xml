                                <PropertyValue Property="Value" Path="Customer" />
                            </Record>
                            <Record Type="UI.DataField">
                                <PropertyValue Property="Label" String="Nome do Cliente" />
                                <PropertyValue Property="Value" Path="CustomerName" />
                            </Record>
                            <Record Type="UI.DataField">
                                <PropertyValue Property="Label" String="País" />
                                <PropertyValue Property="Value" Path="County" />
                            </Record>
                        </Collection>
                    </PropertyValue>
